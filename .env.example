APP_ENV=dev
APP_BASE_URL=http://localhost:8080
APP_DOMAIN=localhost:8080
APP_LISTEN_ADDR=:8080
MIGRATIONS_DIR=/srv/migrations
INBOX_MAX_BODY_BYTES=1048576
AP_ALLOW_UNSIGNED_INBOUND=true
AP_SIGNATURE_MAX_SKEW_SECONDS=300
# In prod, APP_BASE_URL and APP_DOMAIN must be your public URL/domain (localhost is rejected).

DB_DSN=postgres://social:social@db:5432/social?sslmode=disable
REDIS_ADDR=redis:6379

# ActivityPub signing keys (server-level or per-actor; start per-actor in DB)
DATA_DIR=/data

# Session/JWT
SESSION_SECRET=change-me-long-random
JWT_ISSUER=gnusocial-modern
JWT_AUDIENCE=gnusocial-modern-web
JWT_SIGNING_KEY=change-me-long-random

# Dev seed credentials
DEV_SEED_PASSWORD=alice12345

# Inbound HTTP rate limiting
RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=30

# Optional auth providers (enable only when set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

META_CLIENT_ID=
META_CLIENT_SECRET=
META_REDIRECT_URL=http://localhost:8080/auth/meta/callback

X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URL=http://localhost:8080/auth/x/callback

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URL=http://localhost:8080/auth/tiktok/callback
